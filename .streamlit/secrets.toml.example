# ─────────────────────────────────────────────────────────
# Streamlit Cloud Secrets Template
# Copy standard text below into your Streamlit Cloud > Settings > Secrets window
# OR rename this file to secrets.toml for local testing
# ─────────────────────────────────────────────────────────

# REQUIRED: API Keys for AI Intelligence
MINDEE_API_KEY = "your_mindee_api_key_here"
OPENROUTER_API_KEY = "your_openrouter_api_key_here"

# OPTIONAL: Enhancements
HUGGINGFACE_API_KEY = "your_huggingface_api_key_here"
FIRECRAWL_API_KEY = "your_firecrawl_api_key_here"

# Deployment URLs
TALENTOS_API_URL = "https://your-deployed-api-url.com"
CANDIDATE_APP_URL = "https://your-candidate-app-url.streamlit.app"

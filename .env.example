# ─────────────────────────────────────────────────────────
# TalentOS Local Configuration File
# Copy this file to `.env` and insert your own API keys.
# ─────────────────────────────────────────────────────────

# REQUIRED: Mindee OCR for parsing Resumes
MINDEE_API_KEY=your_mindee_api_key_here

# REQUIRED: OpenRouter for Claude/LLM generation
OPENROUTER_API_KEY=your_openrouter_api_key_here

# OPTIONAL: HuggingFace API (Alternative to local transformers for ATS/Skill matching)
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# OPTIONAL: FireCrawl for crawling candidate portfolio links
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# URLs for Option B split architecture testing
TALENTOS_API_URL=http://localhost:8000
CANDIDATE_APP_URL=http://localhost:8502
